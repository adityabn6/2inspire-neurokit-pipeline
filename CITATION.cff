    family-names: Jalin
    email: adityabn@umich.edu
    affiliation: "University of Michigan"
license: MIT
repository-code: "https://github.com/adityabn6/2inspire-neurokit-pipeline"
keywords:
  - heart rate variability
  - HRV
  - respiration
  - NeuroKit2
  - Hexoskin
  - ECG
  - cardiorespiratory coupling
  - music performance
